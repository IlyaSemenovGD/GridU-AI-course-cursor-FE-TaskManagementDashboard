{
  "name": "taskmanagementdashboard",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "lint:report": "eslint . -f json -o qa-reports/eslint.json",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lhci": "lhci autorun",
    "qa:dashboard": "node scripts/qa/build-dashboard.mjs",
    "qa:recommendations": "node scripts/qa/ai-recommendations.mjs",
    "qa:aggregate": "node scripts/qa/aggregate-summary.mjs",
    "qa:run": "node scripts/qa/run-all.mjs",
    "qa:report": "npm run qa:aggregate && npm run qa:recommendations && npm run qa:dashboard"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^3.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "tailwindcss": "^4.2.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "vitest": "^3.2.4",
    "jsdom": "^26.1.0",
    "@lhci/cli": "^0.15.1",
    "serve": "^14.2.4",
    "wait-on": "^8.0.3"
  }
}
